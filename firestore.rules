// Firestore Security Rules — Firebase project `gurdiane-75091`
// Rewritten 2026-07-18 to match the ACTUAL shared schema of the three live
// clients on this project. The previous version of this file targeted the old
// `guardianeusf` camelCase schema (families / children / enhancedDailyLogging /
// childDeviceMappings …) and did NOT match anything here — do not restore it.
//
// ───────────────────────────────────────────────────────────────────────────
// THREE CLIENTS SHARE THIS PROJECT — what they are and how they auth:
//
//   1. GuardianeWeb        (Next.js)         — parent, AUTHENTICATED (email/pw)
//   2. GuardParent         (Expo Android)    — parent, AUTHENTICATED (email/pw)
//   3. Guardiane_Android   (RN child device) — child,  *** NO AUTH AT ALL ***
//
// ⚠️  HARD CONSTRAINT: the child device app uses NO Firebase Auth. Its "login"
// is a local QR/AsyncStorage scheme, so `request.auth` is ALWAYS null on its
// traffic. Every collection the child app reads or writes MUST therefore permit
// unauthenticated access, and NO rule on those paths may reference request.auth.
// Adding even Anonymous Auth to the child app is the prerequisite for locking
// these down further — until then, child-touched data is necessarily public.
//
// What this rewrite DOES improve over the previous wide-open state:
//   • Parent-only collections (aiInsights, chatSessions) require auth.
//   • Parent-only WRITES (users, emergency_contacts, modules, assignments,
//     deletes on messages/learning_progress) require auth + ownership.
//   • jojoLeads stays create-only + strictly shape-validated, never readable.
//   • Everything not explicitly listed is denied (default-deny at the bottom).
//
// Collections that are read/written by the no-auth child app and so remain
// publicly accessible by necessity: users(get), mood_entries, screen_time_entries,
// messages, conversations, learning_progress, lesson_streaks, module_assignments,
// modules(+lessons), emergency_contacts(read).
// ───────────────────────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ── users ────────────────────────────────────────────────────────────────
    // Parents (both apps) and children both live here, distinguished by `role`.
    // Child app: reads a single user doc by id (its own child doc + its parent
    // doc) UNauthenticated — so `get` is public, but enumerating the collection
    // (`list`) requires auth. The child app never writes here; parent apps do.
    match /users/{userId} {
      allow get: if true;
      allow list: if isAuthenticated();

      // A parent may write their own doc, or a child doc they own (child docs
      // carry `parentId` == the parent's uid).
      allow create: if isAuthenticated() &&
                       (userId == request.auth.uid ||
                        request.resource.data.parentId == request.auth.uid);
      allow update, delete: if isAuthenticated() &&
                       (userId == request.auth.uid ||
                        resource.data.parentId == request.auth.uid);

      // GuardParent stores its JoJo history under the parent's own user doc.
      match /jojoConversations/{conversationId} {
        allow read, write: if isOwner(userId);
        match /messages/{messageId} {
          allow read, write: if isOwner(userId);
        }
      }
    }

    // ── mood_entries ─────────────────────────────────────────────────────────
    // Written + deleted by the child app (no auth); read by everyone.
    match /mood_entries/{entryId} {
      allow read: if true;
      allow create: if request.resource.data.childId is string;
      allow update: if false;   // no client updates mood entries in place
      allow delete: if true;    // child app prunes its own entries (unauth)
    }

    // ── screen_time_entries ──────────────────────────────────────────────────
    // Written + deleted by the child app (no auth); read by everyone.
    match /screen_time_entries/{entryId} {
      allow read: if true;
      allow create: if request.resource.data.childId is string;
      allow update: if false;
      allow delete: if true;
    }

    // ── messages (parent ↔ child chat) ───────────────────────────────────────
    // Both sides create; either side toggles isRead (child side is unauth, so
    // create/read/update cannot require auth). Only the parent apps delete.
    match /messages/{messageId} {
      allow read: if true;
      allow create: if request.resource.data.childId is string &&
                       request.resource.data.senderType in ['parent', 'child'];
      allow update: if true;
      allow delete: if isAuthenticated();
    }

    // ── conversations (child-app JoJo history) ───────────────────────────────
    // Child app only, fully unauthenticated.
    match /conversations/{conversationId} {
      allow read, create, update: if true;
      allow delete: if false;
      match /messages/{messageId} {
        allow read, create: if true;
        allow update, delete: if false;
      }
    }

    // ── emergency_contacts ───────────────────────────────────────────────────
    // Read by the child app (unauth). Only the owning parent writes.
    match /emergency_contacts/{contactId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
                       request.resource.data.parentId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
                       resource.data.parentId == request.auth.uid;
    }

    // ── modules (+ lessons) — shared learning content ────────────────────────
    // Read by the child app (unauth). Created/edited by authenticated parents;
    // the "only the creator edits" rule is enforced in app code.
    match /modules/{moduleId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
      match /lessons/{lessonId} {
        allow read: if true;
        allow write: if isAuthenticated();
      }
    }

    // ── module_assignments ───────────────────────────────────────────────────
    // Read by the child app (unauth). Written by authenticated parents.
    match /module_assignments/{assignmentId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }

    // ── learning_progress ────────────────────────────────────────────────────
    // Written by the child app as it completes lessons (no auth). Parents read
    // and may delete.
    match /learning_progress/{progressId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAuthenticated();
    }

    // ── lesson_streaks (child-app only) ──────────────────────────────────────
    match /lesson_streaks/{childId} {
      allow read, create, update: if true;
      allow delete: if false;
    }

    // ── aiInsights (GuardParent only, authenticated) ─────────────────────────
    match /aiInsights/{childId} {
      allow read, write: if isAuthenticated();
    }

    // ── chatSessions (GuardianeWeb JoJo history, per-user) ───────────────────
    match /chatSessions/{sessionId} {
      allow read: if isAuthenticated() &&
                     resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.createdAt is timestamp;
      // Updates may not reassign ownership or rewrite createdAt.
      allow update: if isAuthenticated() &&
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.userId == resource.data.userId &&
                       request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() &&
                       resource.data.userId == request.auth.uid;

      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
                       get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.userId == request.auth.uid;
        allow create: if isAuthenticated() &&
                         get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.userId == request.auth.uid &&
                         request.resource.data.timestamp is timestamp;
        allow update, delete: if false;   // messages are immutable
      }
    }

    // ── jojoLeads (public, login-free chatbot lead capture) ──────────────────
    // The ONLY intentionally-unauthenticated WRITE with a strict shape check.
    // Never client-readable — the team reads leads from the Firebase console.
    function validJojoLead(data) {
      return data.keys().hasOnly(['email', 'phone', 'name', 'childInfo', 'zip', 'source', 'createdAt']) &&
             data.createdAt is timestamp &&
             data.email is string && data.email.size() <= 254 &&
             data.phone is string && data.phone.size() <= 32 &&
             (data.email.size() >= 3 || data.phone.size() >= 7) &&
             data.name is string && data.name.size() <= 100 &&
             data.childInfo is string && data.childInfo.size() <= 500 &&
             data.zip is string && data.zip.size() <= 20 &&
             data.source is string && data.source.size() <= 40;
    }
    match /jojoLeads/{leadId} {
      allow create: if validJojoLead(request.resource.data);
      allow read, update, delete: if false;
    }

    // ── DEFAULT DENY — anything not matched above is rejected ─────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
